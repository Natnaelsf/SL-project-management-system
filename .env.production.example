# Database
DATABASE_URL="postgresql://slpcms:STRONG_PASSWORD@postgres:5432/slpcms?schema=public"

# JWT - CHANGE THESE IN PRODUCTION!
JWT_SECRET="replace-with-a-strong-random-secret-at-least-32-chars"
JWT_REFRESH_SECRET="replace-with-another-strong-random-secret-at-least-32-chars"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Node Environment
NODE_ENV=production

# Backend Port
PORT=4000

# API Prefix
API_PREFIX=/api/v1

# Upload Directory
UPLOAD_DIR=./uploads

# Max File Size (bytes) - 10MB
MAX_FILE_SIZE=10485760

# CORS Origin - Change to your domain
CORS_ORIGIN=https://your-domain.com

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Frontend
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
NEXT_PUBLIC_APP_NAME="SLPCMS"
NEXT_PUBLIC_APP_DESCRIPTION="Street Light Project & Contract Management System"
